# ─── Configuración del modelo BERTopic ───────────────────────────────────────
BERTOPIC_MIN_TOPIC_SIZE=30
BERTOPIC_TOP_N_WORDS=10

# ─── Modelo spaCy ────────────────────────────────────────────────────────────
SPACY_MODEL=es_core_news_sm

# ─── Umbrales de clasificación de impacto (pageviews) ────────────────────────
PV_CRITICO_ALTO=5000
PV_ENTRETENIMIENTO_VIRAL=3000
PV_SOCIAL_TENDENCIA=2000
PV_GENERAL_DESTACABLE=1500

# ─── Exportación ─────────────────────────────────────────────────────────────
CSV_ENCODING=utf-8-sig
DASHBOARD_DPI=300

# ─── Logging ─────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
